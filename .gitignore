# ── Local act / workflow testing ──────────────────────────────────────────────
event.json
.actrc

# ── Secrets & environment vars ────────────────────────────────────────────────
.secrets
.vars

# ── Modpack build output ──────────────────────────────────────────────────────
**/build/
*.mrpack
*.zip

# Allow packcore config zips (these are source files, not build output)
!**/packcore/configs/*.zip

# ── Pakku temporary diff file ─────────────────────────────────────────────────
**/.pakku/lock.old.json

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo

# ── Docker (local build artefacts only — source stays in .github/scripts/docker)
**/.docker-build/

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
